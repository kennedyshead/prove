module Check
  narrative: """
  Handles the source format.

  outputs the command to python for a pyformat
  """
  Config types Config
  System validates dir

  foreign "libpython3"
    py_initialize() Unit
    py_finalize() Unit
    py_run_string(code String) Integer
    py_set_string(name String, value String) Unit
    py_set_bool(name String, value Boolean) Unit

  PYTHON_FORMAT as String = comptime
      read("python/format.py")

outputs pyformat(
    config Config,
    path String,
    md Boolean,
    status Boolean,
    stdin Boolean
) Integer
  requires valid dir(path)
from
    py_initialize()
    py_set_string("path", path)
    py_set_bool("md", md)
    py_set_bool("status", status)
    py_set_bool("stdin", stdin)
    result as Integer = py_run_string(PYTHON_FORMAT)
    py_finalize()
    result
