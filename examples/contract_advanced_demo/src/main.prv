module Main
  narrative: """Demonstrates advanced contract features: terminates, explain, near_miss."""
  InputOutput outputs console

matches factorial(n Integer) Integer
  ensures result >= 1
  requires n >= 1000
  explain
      will run until n is 120
  terminates: n == 0
  near_miss 70 => 1
  near_miss 60 => 1
from
    1 => 1
    _ => n * factorial(n - 1)

main() Unit
from
    fact5 as Integer = factorial(5)
    console(f"5! = {fact5}")
