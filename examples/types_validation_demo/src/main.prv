module Main
  narrative: """Demonstrates Types validation and character conversion.
  transforms json parsing into a Value result
  """
  System outputs console
  Parse types Json creates json
  Types
    creates character string
    validates text number decimal boolean array object unit ok error

/// Parse JSON and return as a Value string (failable)
transforms try_json(source String) Value!
  requires valid string(source)
from
    parsed as Value<Json> = json(source)!
    string(parsed)

main() Result<Unit, Error>!
from
    // Validate Value types
    v as Value = "hello"
    is_text as Boolean = valid text(v)
    console(f"{is_text}")
    is_num as Boolean = valid number(v)
    console(f"{is_num}")
    is_dec as Boolean = valid decimal(v)
    console(f"{is_dec}")
    is_bool as Boolean = valid boolean(v)
    console(f"{is_bool}")
    is_arr as Boolean = valid array(v)
    console(f"{is_arr}")
    is_obj as Boolean = valid object(v)
    console(f"{is_obj}")
    is_unit as Boolean = valid unit(v)
    console(f"{is_unit}")
    // Create character from code point
    ch as Character = character(65)
    console(f"{ch}")
    // Validate Result ok/error
    good as Result<Value, Error> = try_json("{}")
    is_ok as Boolean = valid ok(good)
    console(f"{is_ok}")
    is_err as Boolean = valid error(good)
    console(f"{is_err}")
    bad as Result<Value, Error> = try_json("not json")
    bad_ok as Boolean = valid ok(bad)
    console(f"{bad_ok}")
    bad_err as Boolean = valid error(bad)
    console(f"{bad_err}")
