module Log
  narrative: """Console color constants for terminal output."""
  InputOutput outputs console

  RESET as String = "[0m"

  BOLD as String = "[1m"

  DIM as String = "[2m"

  RED as String = "[31m"

  GREEN as String = "[32m"

  YELLOW as String = "[33m"

  BLUE as String = "[34m"

  MAGENTA as String = "[35m"

  CYAN as String = "[36m"

  WHITE as String = "[37m"

detached debug(string String)
from
    console(f"{BLUE}[DEBUG]{string}{RESET}")

detached info(string String)
from
    console(f"{GREEN}[INFO]{string}{RESET}")

detached warning(string String)
from
    console(f"{YELLOW}[WARNING]{string}{RESET}")

detached error(string String)
from
    console(f"{RED}[ERROR]{string}{RESET}")
