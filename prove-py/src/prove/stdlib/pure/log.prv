module Log
  narrative: """Console color constants for terminal output."""
  InputOutput outputs console
  Time inputs time, types Time
  Format transforms time

  RESET as String = "[0m"

  BOLD as String = "[1m"

  DIM as String = "[2m"

  RED as String = "[31m"

  GREEN as String = "[32m"

  YELLOW as String = "[33m"

  BLUE as String = "[34m"

  MAGENTA as String = "[35m"

  CYAN as String = "[36m"

  WHITE as String = "[37m"

detached debug(string String)
from
    now as Time = time()
    console(f"{BLUE}[DEBUG][{time(now, "HH:ii")}] {string}{RESET}")

detached info(string String)
from
    now as Time = time()
    console(f"{GREEN}[INFO][{time(now, "HH:ii")}] {string}{RESET}")

detached warning(string String)
from
    now as Time = time()
    console(f"{YELLOW}[WARNING][{time(now, "HH:ii")}] {string}{RESET}")

detached error(string String)
from
    now as Time = time()
    console(f"{RED}[ERROR][{time(now, "HH:ii")}] {string}{RESET}")
