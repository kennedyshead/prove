module Main
  narrative: """Demonstrates Format module operations.

  Intentional parse errors (quote issues). Expected to fail: check, check_md, check_strict, build, build_debug, build_mutate, view.
  """
  InputOutput outputs console
  Format transforms hex pad_left

main() Result<Unit, Error>!
from
    console(f"hex(255) = {hex(255)}")
    console(f"pad_left('hi', 10, '*') = {pad_left("hi", 10, '*')}")
