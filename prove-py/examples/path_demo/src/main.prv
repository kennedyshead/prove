module Main
  narrative: """Demonstrates Path module operations.

  Missing runtime dependencies (build fails). Expected to fail: check, check_md, check_strict, build, build_debug, build_mutate, view.
  """
  InputOutput outputs console
  Path reads parent stem extension

main() Result<Unit, Error>!
from
    p as String = "/home/user/file.txt"
    console(f"parent = {parent(p)}")
    console(f"stem = {stem(p)}")
    console(f"extension = {extension(p)}")
