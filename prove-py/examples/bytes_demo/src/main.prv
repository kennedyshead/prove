module Main
  narrative: """Demonstrates Bytes module operations."""
  InputOutput outputs console
  Bytes types ByteArray
  Bytes creates byte hex
  Bytes reads hex at

main() Result<Unit, Error>!
from
    data as ByteArray = byte([72, 101, 108, 108, 111])
    encoded as String = hex(data)
    console(f"hex: {encoded}")
    first as Integer = at(data, 0)
    console(f"first byte: {first}")
    decoded as ByteArray = hex("48656c6c6f")
    console(f"decoded hex: {hex(decoded)}")
