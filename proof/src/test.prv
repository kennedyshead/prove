module Test
  narrative: """
  Handles the source check.

  outputs the command to python for a pytest
  dispatches the test command
  """
  Config types Config inputs config
  System validates dir inputs cwd outputs console
  Log detached info

  foreign "libpython3"
    py_initialize() Unit
    py_finalize() Unit
    py_run_string(code String) Integer
    py_set_string(name String, value String) Unit
    py_set_integer(name String, value Integer) Unit

  PYTHON_TEST as String = comptime
      read("python/test.py")

  HELP_TEST_TEXT as String = comptime
      read("static/cli/test.txt")

/// Run the test command
dispatches test(help Boolean, arguments List<String>)!
from
    true => console(HELP_TEST_TEXT)
    _ =>
        config as Config = config()!
        pytest(config, cwd())!
        info(f"{config.package.name}{config.package.version}")&

outputs pytest(config Config, path String) Integer!
  requires valid dir(path)
from
    py_initialize()
    py_set_string("path", path)
    // TODO: map property_rounds
    py_set_integer("property_rounds", config.test.property_rounds)
    result as Integer = py_run_string(PYTHON_TEST)
    py_finalize()
    result
