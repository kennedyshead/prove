module Source
  narrative: """
  Inputs all source files trough dir inputs.
  Reads all source content of files.
  """
  Config types Config
  System validates file inputs dir file
  Text validates ends

  type SourceFile is
    path String
    content String

inputs content(path String) String
  requires valid ends(path, ".prv") && valid file(path)
from
    file(path)

inputs source(config Config) List<SourceFile>
from
    map(dir("src/"), |value| SourceFile(value.path, content(value.path)))
