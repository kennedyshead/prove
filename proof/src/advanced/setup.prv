module Setup
  narrative: """
  Handles the setup.

  outputs the command to python for a pysetup
  """

  foreign "libpython3"
    py_initialize() Unit
    py_finalize() Unit
    py_run_string(code String) Integer

  PYTHON_LSP as String = comptime
      read("../python/setup.py")

outputs pysetup() Integer
from
    py_initialize()
    result as Integer = py_run_string(PYTHON_LSP)
    py_finalize()
    result
